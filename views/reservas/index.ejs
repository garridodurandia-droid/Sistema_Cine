<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Reservas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .reservation-card {
            transition: transform 0.3s ease;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .reservation-card:hover {
            transform: translateY(-5px);
        }
        .loading-spinner {
            display: none;
        }
        .alert-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1050;
            min-width: 300px;
        }
        .status-badge {
            font-size: 0.8em;
        }
        .revenue-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-film me-2"></i>CineSystem</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/peliculas"><i class="fas fa-movie me-1"></i>Películas</a>
                <a class="nav-link" href="/salas"><i class="fas fa-theater-masks me-1"></i>Salas</a>
                <a class="nav-link" href="/funciones"><i class="fas fa-calendar-alt me-1"></i>Funciones</a>
                <a class="nav-link" href="/clientes"><i class="fas fa-users me-1"></i>Clientes</a>
                <a class="nav-link active" href="/reservas"><i class="fas fa-ticket-alt me-1"></i>Reservas</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold text-danger"><i class="fas fa-ticket-alt me-2"></i>Gestión de Reservas</h1>
                <p class="lead">Administra las reservas de tus clientes</p>
            </div>
        </div>

        <!-- Estadísticas -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h4 id="totalReservas">0</h4>
                        <p class="mb-0">Total Reservas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h4 id="reservasHoy">0</h4>
                        <p class="mb-0">Hoy</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center">
                        <h4 id="totalAsientos">0</h4>
                        <p class="mb-0">Asientos Vend.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card revenue-card">
                    <div class="card-body text-center">
                        <h4 id="ingresosReservas">$0</h4>
                        <p class="mb-0">Ingresos</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Formulario -->
            <div class="col-lg-6">
                <div class="card reservation-card">
                    <div class="card-header bg-danger text-white">
                        <h4 class="mb-0"><i class="fas fa-ticket-alt me-2"></i>Nueva Reserva</h4>
                    </div>
                    <div class="card-body">
                        <form id="formReserva">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Función ID *</label>
                                    <input type="number" class="form-control" id="funcionId" placeholder="ID de la función" required>
                                    <div class="form-text">
                                        <small>ID de la función existente</small>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Cliente ID *</label>
                                    <input type="number" class="form-control" id="clienteId" placeholder="ID del cliente" required>
                                    <div class="form-text">
                                        <small>ID del cliente existente</small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Número de Asientos *</label>
                                    <input type="number" class="form-control" id="asientos" min="1" max="10" value="1" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Total a Pagar ($)</label>
                                    <input type="number" step="0.01" class="form-control" id="total" readonly>
                                </div>
                            </div>

                            <div class="alert alert-info" id="infoFuncion">
                                <i class="fas fa-info-circle me-2"></i>
                                <small>Selecciona una función y cliente válidos</small>
                            </div>

                            <button type="submit" class="btn btn-danger w-100" id="btnSubmit">
                                <i class="fas fa-shopping-cart me-2"></i>Confirmar Reserva
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Búsqueda por Fecha -->
                <div class="card reservation-card mt-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-search me-2"></i>Buscar Reservas</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Desde</label>
                                <input type="date" class="form-control" id="fechaInicio">
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-control" id="fechaFin">
                            </div>
                        </div>
                        <button class="btn btn-outline-info w-100" onclick="buscarReservasPorFecha()">
                            <i class="fas fa-filter me-2"></i>Filtrar Reservas
                        </button>
                        <button class="btn btn-outline-secondary w-100 mt-2" onclick="cargarReservas()">
                            <i class="fas fa-sync-alt me-2"></i>Mostrar Todas
                        </button>
                    </div>
                </div>
            </div>

            <!-- Lista de Reservas -->
            <div class="col-lg-6">
                <div class="card reservation-card">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Reservas</h4>
                        <div>
                            <span class="badge bg-light text-dark" id="contadorReservas">0 reservas</span>
                            <button class="btn btn-sm btn-light ms-2" onclick="cargarReservas()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="loading-spinner text-center mb-3" id="loadingReservas">
                            <div class="spinner-border text-danger" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando reservas...</p>
                        </div>
                        <div id="listaReservas" class="row g-3">
                            <!-- Las reservas se cargarán aquí -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Cargar reservas al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            // Establecer fechas por defecto
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('fechaInicio').value = today;
            document.getElementById('fechaFin').value = today;
            
            cargarReservas();
            
            // Calcular total cuando cambian los asientos
            document.getElementById('asientos').addEventListener('input', calcularTotal);
        });

        // Calcular total basado en asientos (simulado)
        function calcularTotal() {
            const asientos = document.getElementById('asientos').value;
            // En una app real, aquí buscarías el precio de la función
            const precioPorAsiento = 5.00; // Precio simulado
            const total = asientos * precioPorAsiento;
            document.getElementById('total').value = total.toFixed(2);
        }

        // Manejar envío del formulario
        document.getElementById('formReserva').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btnSubmit = document.getElementById('btnSubmit');
            const originalText = btnSubmit.innerHTML;
            
            btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Procesando...';
            btnSubmit.disabled = true;
            
            const reservaData = {
                funcionId: document.getElementById('funcionId').value,
                clienteId: document.getElementById('clienteId').value,
                asientos: document.getElementById('asientos').value,
                total: document.getElementById('total').value
            };

            try {
                const response = await fetch('http://localhost:3000/api/reservas', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(reservaData)
                });

                if (response.ok) {
                    showAlert('¡Reserva confirmada correctamente!', 'success');
                    document.getElementById('formReserva').reset();
                    await cargarReservas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al crear reserva', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión con el servidor', 'danger');
            } finally {
                btnSubmit.innerHTML = originalText;
                btnSubmit.disabled = false;
            }
        });

        // Función para cargar y mostrar reservas
        async function cargarReservas() {
            const loadingElement = document.getElementById('loadingReservas');
            const listaElement = document.getElementById('listaReservas');
            
            loadingElement.style.display = 'block';
            listaElement.innerHTML = '';
            
            try {
                const response = await fetch('http://localhost:3000/api/reservas');
                const reservas = await response.json();
                
                // Actualizar estadísticas
                actualizarEstadisticasReservas(reservas);
                
                const contador = document.getElementById('contadorReservas');
                contador.textContent = `${reservas.length} reserva${reservas.length !== 1 ? 's' : ''}`;
                
                if (reservas.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay reservas registradas
                            </div>
                        </div>
                    `;
                    return;
                }
                
                // Mostrar reservas
                reservas.forEach(reserva => {
                    const fechaReserva = new Date(reserva.fechaReserva);
                    const ahora = new Date();
                    const esReciente = (ahora - fechaReserva) < (24 * 60 * 60 * 1000); // Menos de 24 horas
                    
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card reservation-card ${esReciente ? 'border-success' : ''}">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="card-title text-danger">Reserva #${reserva.id}</h5>
                                            <span class="badge ${esReciente ? 'bg-success' : 'bg-secondary'} status-badge">
                                                ${esReciente ? 'NUEVA' : 'CONFIRMADA'}
                                            </span>
                                        </div>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-user me-1 text-muted"></i>
                                            <strong>Cliente:</strong> ${reserva.cliente?.nombre || 'Cliente no encontrado'}
                                        </p>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-film me-1 text-muted"></i>
                                            <strong>Película:</strong> ${reserva.funcion?.pelicula?.titulo || 'Película no disponible'}
                                        </p>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-calendar me-1 text-muted"></i>
                                            <small class="text-muted">
                                                Función: ${reserva.funcion?.fecha ? new Date(reserva.funcion.fecha).toLocaleDateString() : 'N/A'} 
                                                ${reserva.funcion?.hora || ''}
                                            </small>
                                        </p>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-chair me-1 text-muted"></i>
                                            <strong>Asientos:</strong> ${reserva.asientos} | 
                                            <strong>Total:</strong> $${reserva.total}
                                        </p>
                                        
                                        <small class="text-muted">
                                            Reserva realizada: ${fechaReserva.toLocaleString()}
                                        </small>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <button class="btn btn-outline-danger btn-sm" onclick="eliminarReserva(${reserva.id})">
                                            <i class="fas fa-trash me-1"></i>Cancelar
                                        </button>
                                        <br>
                                        <small class="text-muted mt-2 d-block">
                                            Estado: <span class="text-success">${reserva.estado || 'confirmada'}</span>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });
                
            } catch (error) {
                console.error('Error al cargar reservas:', error);
                listaElement.innerHTML = `
                    <div class="col-12 text-center">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Error al cargar las reservas
                        </div>
                    </div>
                `;
            } finally {
                loadingElement.style.display = 'none';
            }
        }

        // Actualizar estadísticas de reservas
        function actualizarEstadisticasReservas(reservas) {
            const hoy = new Date().toDateString();
            let totalAsientos = 0;
            let ingresosTotales = 0;
            let reservasHoy = 0;

            reservas.forEach(reserva => {
                const fechaReserva = new Date(reserva.fechaReserva).toDateString();
                if (fechaReserva === hoy) {
                    reservasHoy++;
                }
                totalAsientos += parseInt(reserva.asientos) || 0;
                ingresosTotales += parseFloat(reserva.total) || 0;
            });

            document.getElementById('totalReservas').textContent = reservas.length;
            document.getElementById('reservasHoy').textContent = reservasHoy;
            document.getElementById('totalAsientos').textContent = totalAsientos;
            document.getElementById('ingresosReservas').textContent = `$${ingresosTotales.toFixed(2)}`;
        }

        // Buscar reservas por fecha
        async function buscarReservasPorFecha() {
            const fechaInicio = document.getElementById('fechaInicio').value;
            const fechaFin = document.getElementById('fechaFin').value;

            if (!fechaInicio || !fechaFin) {
                showAlert('Selecciona ambas fechas', 'warning');
                return;
            }

            try {
               const response = await fetch(`/api/reservas/rango-fecha?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`);
                const reservas = await response.json();
                
                const listaElement = document.getElementById('listaReservas');
                listaElement.innerHTML = '';
                
                if (reservas.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay reservas en el rango seleccionado
                            </div>
                        </div>
                    `;
                    return;
                }

                reservas.forEach(reserva => {
                    const fechaReserva = new Date(reserva.fechaReserva);
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card reservation-card">
                            <div class="card-body">
                                <h5 class="card-title text-danger">Reserva #${reserva.id}</h5>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        Cliente ID: ${reserva.clienteId} | Función ID: ${reserva.funcionId}
                                    </small>
                                </p>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        ${reserva.asientos} asientos | $${reserva.total} | ${fechaReserva.toLocaleDateString()}
                                    </small>
                                </p>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });

                showAlert(`Se encontraron ${reservas.length} reservas`, 'info');
                
            } catch (error) {
                console.error('Error buscando reservas:', error);
                showAlert('Error al buscar reservas', 'danger');
            }
        }

        // Función para eliminar reserva
        async function eliminarReserva(id) {
            if (!confirm('¿Está seguro de cancelar esta reserva? Los asientos se liberarán.')) {
                return;
            }

            try {
                const response = await fetch(`http://localhost:3000/api/reservas/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Reserva cancelada correctamente', 'success');
                    await cargarReservas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al cancelar reserva', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión al cancelar', 'danger');
            }
        }

        // Función para mostrar alertas
        function showAlert(message, type) {
            const existingAlerts = document.querySelectorAll('.alert-toast');
            existingAlerts.forEach(alert => alert.remove());

            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show alert-toast`;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-exclamation-circle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 4000);
        }
    </script>
</body>
</html>
