<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Funciones</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .function-card {
            transition: transform 0.3s ease;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .function-card:hover {
            transform: translateY(-5px);
        }
        .loading-spinner {
            display: none;
        }
        .alert-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1050;
            min-width: 300px;
        }
        .status-badge {
            font-size: 0.8em;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-film me-2"></i>CineSystem</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/peliculas"><i class="fas fa-movie me-1"></i>Películas</a>
                <a class="nav-link" href="/salas"><i class="fas fa-theater-masks me-1"></i>Salas</a>
                <a class="nav-link active" href="/funciones"><i class="fas fa-calendar-alt me-1"></i>Funciones</a>
                <a class="nav-link" href="/clientes"><i class="fas fa-users me-1"></i>Clientes</a>
                <a class="nav-link" href="/reservas"><i class="fas fa-ticket-alt me-1"></i>Reservas</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold text-warning"><i class="fas fa-calendar-alt me-2"></i>Gestión de Funciones</h1>
                <p class="lead">Programa y gestiona las funciones de cine</p>
            </div>
        </div>

        <!-- Estadísticas Rápidas -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h4 id="totalFunciones">0</h4>
                        <p class="mb-0">Total Funciones</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h4 id="funcionesHoy">0</h4>
                        <p class="mb-0">Hoy</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h4 id="asientosDisponibles">0</h4>
                        <p class="mb-0">Asientos Disp.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center">
                        <h4 id="ingresosTotales">$0</h4>
                        <p class="mb-0">Ingresos Totales</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Formulario -->
            <div class="col-lg-6">
                <div class="card function-card">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Programar Nueva Función</h4>
                    </div>
                    <div class="card-body">
                        <form id="formFuncion">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Película ID *</label>
                                    <input type="number" class="form-control" id="peliculaId" placeholder="ID de la película" required>
                                    <div class="form-text">
                                        <small>Usa el ID de una película existente</small>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Sala ID *</label>
                                    <input type="number" class="form-control" id="salaId" placeholder="ID de la sala" required>
                                    <div class="form-text">
                                        <small>Usa el ID de una sala existente</small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Fecha *</label>
                                    <input type="date" class="form-control" id="fecha" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Hora *</label>
                                    <input type="time" class="form-control" id="hora" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Precio por Asiento ($) *</label>
                                <input type="number" step="0.01" class="form-control" id="precio" placeholder="0.00" required>
                            </div>

                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                <small>La capacidad de la sala se asignará automáticamente</small>
                            </div>

                            <button type="submit" class="btn btn-warning w-100" id="btnSubmit">
                                <i class="fas fa-calendar-plus me-2"></i>Programar Función
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Búsqueda por Fecha -->
                <div class="card function-card mt-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-search me-2"></i>Buscar por Fecha</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Desde</label>
                                <input type="date" class="form-control" id="fechaInicio">
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-control" id="fechaFin">
                            </div>
                        </div>
                        <button class="btn btn-outline-info w-100" onclick="buscarPorFecha()">
                            <i class="fas fa-filter me-2"></i>Filtrar Funciones
                        </button>
                    </div>
                </div>
            </div>

            <!-- Lista de Funciones -->
            <div class="col-lg-6">
                <div class="card function-card">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Funciones</h4>
                        <div>
                            <span class="badge bg-light text-dark" id="contadorFunciones">0 funciones</span>
                            <button class="btn btn-sm btn-light ms-2" onclick="cargarFunciones()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="loading-spinner text-center mb-3" id="loadingFunciones">
                            <div class="spinner-border text-warning" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando funciones...</p>
                        </div>
                        <div id="listaFunciones" class="row g-3">
                            <!-- Las funciones se cargarán aquí -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Cargar funciones al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            // Establecer fecha mínima como hoy
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('fecha').min = today;
            document.getElementById('fechaInicio').value = today;
            document.getElementById('fechaFin').value = today;
            
            cargarFunciones();
        });

        // Manejar envío del formulario
        document.getElementById('formFuncion').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btnSubmit = document.getElementById('btnSubmit');
            const originalText = btnSubmit.innerHTML;
            
            btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Programando...';
            btnSubmit.disabled = true;
            
            const funcionData = {
                peliculaId: document.getElementById('peliculaId').value,
                salaId: document.getElementById('salaId').value,
                fecha: document.getElementById('fecha').value,
                hora: document.getElementById('hora').value,
                precio: document.getElementById('precio').value
            };

            try {
                const response = await fetch('http://localhost:3000/api/funciones', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(funcionData)
                });

                if (response.ok) {
                    showAlert('¡Función programada correctamente!', 'success');
                    document.getElementById('formFuncion').reset();
                    await cargarFunciones();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al programar función', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión con el servidor', 'danger');
            } finally {
                btnSubmit.innerHTML = originalText;
                btnSubmit.disabled = false;
            }
        });

        // Función para cargar y mostrar funciones
        async function cargarFunciones() {
            const loadingElement = document.getElementById('loadingFunciones');
            const listaElement = document.getElementById('listaFunciones');
            
            loadingElement.style.display = 'block';
            listaElement.innerHTML = '';
            
            try {
                const response = await fetch('http://localhost:3000/api/funciones');
                const funciones = await response.json();
                
                // Actualizar estadísticas
                actualizarEstadisticas(funciones);
                
                const contador = document.getElementById('contadorFunciones');
                contador.textContent = `${funciones.length} función${funciones.length !== 1 ? 'es' : ''}`;
                
                if (funciones.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay funciones programadas
                            </div>
                        </div>
                    `;
                    return;
                }
                
                // Mostrar funciones
                funciones.forEach(funcion => {
                    const fechaFuncion = new Date(funcion.fecha);
                    const ahora = new Date();
                    const esPasada = fechaFuncion < ahora;
                    
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card function-card ${esPasada ? 'border-secondary' : ''}">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="card-title text-warning">${funcion.pelicula?.titulo || 'Película no encontrada'}</h5>
                                            <span class="badge ${esPasada ? 'bg-secondary' : 'bg-success'} status-badge">
                                                ${esPasada ? 'PASADA' : 'ACTIVA'}
                                            </span>
                                        </div>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-theater-masks me-1 text-muted"></i>
                                            <small class="text-muted">Sala ${funcion.sala?.numero || 'N/A'} | Capacidad: ${funcion.sala?.capacidad || 'N/A'}</small>
                                        </p>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-calendar me-1 text-muted"></i>
                                            <small class="text-muted">
                                                ${fechaFuncion.toLocaleDateString()} a las ${funcion.hora}
                                            </small>
                                        </p>
                                        
                                        <p class="card-text mb-1">
                                            <i class="fas fa-ticket-alt me-1 text-muted"></i>
                                            <small class="text-muted">
                                                $${funcion.precio} por asiento | 
                                                <span class="${funcion.asientosDisponibles < 10 ? 'text-danger' : 'text-success'}">
                                                    ${funcion.asientosDisponibles} asientos disponibles
                                                </span>
                                            </small>
                                        </p>
                                        
                                        <small class="text-muted">
                                            ID: ${funcion.id} | Creada: ${new Date(funcion.fechaCreacion).toLocaleDateString()}
                                        </small>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <button class="btn btn-outline-danger btn-sm mb-2" onclick="eliminarFuncion(${funcion.id})">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </button>
                                        <br>
                                        <small class="text-muted">
                                            ${funcion.asientosDisponibles}/${funcion.sala?.capacidad || 0} disp.
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });
                
            } catch (error) {
                console.error('Error al cargar funciones:', error);
                listaElement.innerHTML = `
                    <div class="col-12 text-center">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Error al cargar las funciones
                        </div>
                    </div>
                `;
            } finally {
                loadingElement.style.display = 'none';
            }
        }

        // Actualizar estadísticas
        function actualizarEstadisticas(funciones) {
            const hoy = new Date().toDateString();
            let totalAsientos = 0;
            let ingresosTotales = 0;
            let funcionesHoy = 0;

            funciones.forEach(funcion => {
                const fechaFuncion = new Date(funcion.fecha).toDateString();
                if (fechaFuncion === hoy) {
                    funcionesHoy++;
                }
                totalAsientos += funcion.asientosDisponibles || 0;
                ingresosTotales += (funcion.sala?.capacidad - funcion.asientosDisponibles) * funcion.precio || 0;
            });

            document.getElementById('totalFunciones').textContent = funciones.length;
            document.getElementById('funcionesHoy').textContent = funcionesHoy;
            document.getElementById('asientosDisponibles').textContent = totalAsientos;
            document.getElementById('ingresosTotales').textContent = `$${ingresosTotales.toFixed(2)}`;
        }

        // Buscar por fecha
        async function buscarPorFecha() {
            const fechaInicio = document.getElementById('fechaInicio').value;
            const fechaFin = document.getElementById('fechaFin').value;

            if (!fechaInicio || !fechaFin) {
                showAlert('Selecciona ambas fechas', 'warning');
                return;
            }

            try {
               const response = await fetch(`/api/funciones/rango-fecha?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`);
                const funciones = await response.json();
                
                const listaElement = document.getElementById('listaFunciones');
                listaElement.innerHTML = '';
                
                if (funciones.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay funciones en el rango seleccionado
                            </div>
                        </div>
                    `;
                    return;
                }

                funciones.forEach(funcion => {
                    const fechaFuncion = new Date(funcion.fecha);
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card function-card">
                            <div class="card-body">
                                <h5 class="card-title text-warning">${funcion.peliculaId ? `Película ID: ${funcion.peliculaId}` : 'Sin película'}</h5>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        Sala: ${funcion.salaId} | ${fechaFuncion.toLocaleDateString()} ${funcion.hora}
                                    </small>
                                </p>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        $${funcion.precio} | ${funcion.asientosDisponibles} asientos disponibles
                                    </small>
                                </p>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });

                showAlert(`Se encontraron ${funciones.length} funciones`, 'info');
                
            } catch (error) {
                console.error('Error buscando por fecha:', error);
                showAlert('Error al buscar funciones', 'danger');
            }
        }

        // Función para eliminar función
        async function eliminarFuncion(id) {
            if (!confirm('¿Está seguro de eliminar esta función? Se perderán todas las reservas asociadas.')) {
                return;
            }

            try {
                const response = await fetch(`http://localhost:3000/api/funciones/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Función eliminada correctamente', 'success');
                    await cargarFunciones();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al eliminar función', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión al eliminar', 'danger');
            }
        }

        // Función para mostrar alertas
        function showAlert(message, type) {
            const existingAlerts = document.querySelectorAll('.alert-toast');
            existingAlerts.forEach(alert => alert.remove());

            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show alert-toast`;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-exclamation-circle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 4000);
        }
    </script>
</body>
</html>