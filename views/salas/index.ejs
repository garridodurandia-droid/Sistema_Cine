<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Salas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .room-card {
            transition: transform 0.3s ease;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .room-card:hover {
            transform: translateY(-5px);
        }
        .capacity-badge {
            font-size: 0.9em;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-film me-2"></i>CineSystem</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/peliculas"><i class="fas fa-movie me-1"></i>Películas</a>
                <a class="nav-link active" href="/salas"><i class="fas fa-theater-masks me-1"></i>Salas</a>
                <a class="nav-link" href="/funciones"><i class="fas fa-calendar-alt me-1"></i>Funciones</a>
                <a class="nav-link" href="/clientes"><i class="fas fa-users me-1"></i>Clientes</a>
                <a class="nav-link" href="/reservas"><i class="fas fa-ticket-alt me-1"></i>Reservas</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold text-success"><i class="fas fa-theater-masks me-2"></i>Gestión de Salas</h1>
                <p class="lead">Administra las salas de proyección</p>
            </div>
        </div>

        <div class="row">
            <!-- Formulario -->
            <div class="col-lg-6">
                <div class="card room-card">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Agregar Nueva Sala</h4>
                    </div>
                    <div class="card-body">
                        <form id="formSala">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Número de Sala *</label>
                                    <input type="number" class="form-control" id="numero" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Capacidad *</label>
                                    <input type="number" class="form-control" id="capacidad" required>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Tipo de Sala</label>
                                <select class="form-select" id="tipo">
                                    <option value="2D">2D Estándar</option>
                                    <option value="3D">3D</option>
                                    <option value="IMAX">IMAX</option>
                                    <option value="VIP">VIP</option>
                                    <option value="4DX">4DX</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Equipamiento</label>
                                <input type="text" class="form-control" id="equipamiento" 
                                       placeholder="Proyector 4K, Sonido Dolby, Butacas reclinables...">
                                <div class="form-text">Separar por comas cada elemento</div>
                            </div>

                            <button type="submit" class="btn btn-success w-100" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Guardar Sala
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Lista de Salas -->
            <div class="col-lg-6">
                <div class="card room-card">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Salas</h4>
                        <div>
                            <span class="badge bg-light text-dark" id="contadorSalas">0 salas</span>
                            <button class="btn btn-sm btn-light ms-2" onclick="cargarSalas()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="loading-spinner text-center mb-3" id="loadingSalas">
                            <div class="spinner-border text-success" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando salas...</p>
                        </div>
                        <div id="listaSalas" class="row g-3">
                            <!-- Las salas se cargarán aquí -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Cargar salas al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            cargarSalas();
        });

        // Manejar envío del formulario
        document.getElementById('formSala').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btnSubmit = document.getElementById('btnSubmit');
            const originalText = btnSubmit.innerHTML;
            
            btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';
            btnSubmit.disabled = true;
            
            const salaData = {
                numero: document.getElementById('numero').value,
                capacidad: document.getElementById('capacidad').value,
                tipo: document.getElementById('tipo').value,
                equipamiento: document.getElementById('equipamiento').value.split(',').map(item => item.trim()).filter(item => item)
            };

            try {
                const response = await fetch('http://localhost:3000/api/salas', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(salaData)
                });

                if (response.ok) {
                    showAlert('¡Sala agregada correctamente!', 'success');
                    document.getElementById('formSala').reset();
                    await cargarSalas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al agregar sala', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión con el servidor', 'danger');
            } finally {
                btnSubmit.innerHTML = originalText;
                btnSubmit.disabled = false;
            }
        });

        // Función para cargar y mostrar salas
        async function cargarSalas() {
            const loadingElement = document.getElementById('loadingSalas');
            const listaElement = document.getElementById('listaSalas');
            
            loadingElement.style.display = 'block';
            listaElement.innerHTML = '';
            
            try {
                const response = await fetch('http://localhost:3000/api/salas');
                const salas = await response.json();
                
                const contador = document.getElementById('contadorSalas');
                contador.textContent = `${salas.length} sala${salas.length !== 1 ? 's' : ''}`;
                
                if (salas.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay salas registradas
                            </div>
                        </div>
                    `;
                    return;
                }
                
                salas.forEach(sala => {
                    const tipoClass = {
                        '2D': 'bg-secondary',
                        '3D': 'bg-info',
                        'IMAX': 'bg-warning text-dark',
                        'VIP': 'bg-dark',
                        '4DX': 'bg-danger'
                    }[sala.tipo] || 'bg-secondary';
                    
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card room-card">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <h5 class="card-title">
                                            Sala ${sala.numero}
                                            <span class="badge ${tipoClass} ms-2">${sala.tipo}</span>
                                        </h5>
                                        <p class="card-text mb-1">
                                            <span class="badge bg-light text-dark capacity-badge">
                                                <i class="fas fa-users me-1"></i>${sala.capacidad} asientos
                                            </span>
                                        </p>
                                        ${sala.equipamiento && sala.equipamiento.length > 0 ? `
                                            <p class="card-text mb-1 small text-muted">
                                                <i class="fas fa-cogs me-1"></i>
                                                ${sala.equipamiento.join(', ')}
                                            </p>
                                        ` : ''}
                                        <small class="text-muted">
                                            Creada: ${new Date(sala.fechaCreacion).toLocaleDateString()}
                                        </small>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <button class="btn btn-outline-danger btn-sm" onclick="eliminarSala(${sala.id})">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });
                
            } catch (error) {
                console.error('Error al cargar salas:', error);
                listaElement.innerHTML = `
                    <div class="col-12 text-center">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Error al cargar las salas
                        </div>
                    </div>
                `;
            } finally {
                loadingElement.style.display = 'none';
            }
        }

        // Función para eliminar sala
        async function eliminarSala(id) {
            if (!confirm('¿Está seguro de eliminar esta sala? Esta acción no se puede deshacer.')) {
                return;
            }

            try {
                const response = await fetch(`http://localhost:3000/api/salas/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Sala eliminada correctamente', 'success');
                    await cargarSalas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al eliminar sala', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión al eliminar', 'danger');
            }
        }

        // Función para mostrar alertas (misma función para todas las vistas)
        function showAlert(message, type) {
            const existingAlerts = document.querySelectorAll('.alert-toast');
            existingAlerts.forEach(alert => alert.remove());

            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show alert-toast`;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 4000);
        }
    </script>
</body>
</html>