<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Películas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .movie-card {
            transition: transform 0.3s ease;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .movie-card:hover {
            transform: translateY(-5px);
        }
        .loading-spinner {
            display: none;
        }
        .alert-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1050;
            min-width: 300px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-film me-2"></i>CineSystem</a>
            <div class="navbar-nav">
                <a class="nav-link active" href="/peliculas"><i class="fas fa-movie me-1"></i>Películas</a>
                <a class="nav-link" href="/salas"><i class="fas fa-theater-masks me-1"></i>Salas</a>
                <a class="nav-link" href="/funciones"><i class="fas fa-calendar-alt me-1"></i>Funciones</a>
                <a class="nav-link" href="/clientes"><i class="fas fa-users me-1"></i>Clientes</a>
                <a class="nav-link" href="/reservas"><i class="fas fa-ticket-alt me-1"></i>Reservas</a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold text-primary"><i class="fas fa-film me-2"></i>Gestión de Películas</h1>
                <p class="lead">Administra el catálogo completo de películas</p>
            </div>
        </div>

        <div class="row">
            <!-- Formulario -->
            <div class="col-lg-6">
                <div class="card movie-card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Agregar Nueva Película</h4>
                    </div>
                    <div class="card-body">
                        <form id="formPelicula">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Título *</label>
                                    <input type="text" class="form-control" id="titulo" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Director *</label>
                                    <input type="text" class="form-control" id="director" required>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Género *</label>
                                    <input type="text" class="form-control" id="genero" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Duración (min) *</label>
                                    <input type="number" class="form-control" id="duracion" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Clasificación</label>
                                <select class="form-select" id="clasificacion">
                                    <option value="A">A - Todo público</option>
                                    <option value="B">B - +12 años</option>
                                    <option value="C">C - +15 años</option>
                                    <option value="D">D - +18 años</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Sinopsis</label>
                                <textarea class="form-control" id="sinopsis" rows="3" placeholder="Breve descripción de la película..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary w-100" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Guardar Película
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Lista de Películas -->
            <div class="col-lg-6">
                <div class="card movie-card">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-list me-2"></i>Lista de Películas</h4>
                        <div>
                            <span class="badge bg-light text-dark" id="contadorPeliculas">0 películas</span>
                            <button class="btn btn-sm btn-light ms-2" onclick="cargarPeliculas()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="loading-spinner text-center mb-3" id="loadingPeliculas">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando películas...</p>
                        </div>
                        <div id="listaPeliculas" class="row g-3">
                            <!-- Las películas se cargarán aquí -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Cargar películas al iniciar
        document.addEventListener('DOMContentLoaded', function() {
            cargarPeliculas();
        });

        // Manejar envío del formulario
        document.getElementById('formPelicula').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btnSubmit = document.getElementById('btnSubmit');
            const originalText = btnSubmit.innerHTML;
            
            // Mostrar loading en el botón
            btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';
            btnSubmit.disabled = true;
            
            const peliculaData = {
                titulo: document.getElementById('titulo').value,
                director: document.getElementById('director').value,
                genero: document.getElementById('genero').value,
                duracion: document.getElementById('duracion').value,
                clasificacion: document.getElementById('clasificacion').value,
                sinopsis: document.getElementById('sinopsis').value
            };

            try {
                const response = await fetch('http://localhost:3000/api/peliculas', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(peliculaData)
                });

                if (response.ok) {
                    showAlert('¡Película agregada correctamente!', 'success');
                    document.getElementById('formPelicula').reset();
                    // Recargar la lista automáticamente
                    await cargarPeliculas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al agregar película', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión con el servidor', 'danger');
            } finally {
                // Restaurar botón
                btnSubmit.innerHTML = originalText;
                btnSubmit.disabled = false;
            }
        });

        // Función para cargar y mostrar películas
        async function cargarPeliculas() {
            const loadingElement = document.getElementById('loadingPeliculas');
            const listaElement = document.getElementById('listaPeliculas');
            
            // Mostrar loading
            loadingElement.style.display = 'block';
            listaElement.innerHTML = '';
            
            try {
                const response = await fetch('http://localhost:3000/api/peliculas');
                const peliculas = await response.json();
                
                const contador = document.getElementById('contadorPeliculas');
                contador.textContent = `${peliculas.length} película${peliculas.length !== 1 ? 's' : ''}`;
                
                if (peliculas.length === 0) {
                    listaElement.innerHTML = `
                        <div class="col-12 text-center">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>No hay películas registradas
                            </div>
                        </div>
                    `;
                    return;
                }
                
                // Mostrar películas
                peliculas.forEach(pelicula => {
                    const div = document.createElement('div');
                    div.className = 'col-12';
                    div.innerHTML = `
                        <div class="card movie-card">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <h5 class="card-title text-primary">${pelicula.titulo}</h5>
                                        <p class="card-text mb-1">
                                            <small class="text-muted">
                                                <i class="fas fa-user me-1"></i>${pelicula.director}
                                            </small>
                                        </p>
                                        <p class="card-text mb-1">
                                            <small class="text-muted">
                                                <i class="fas fa-tag me-1"></i>${pelicula.genero} | 
                                                <i class="fas fa-clock me-1"></i>${pelicula.duracion} min
                                            </small>
                                        </p>
                                        ${pelicula.sinopsis ? `<p class="card-text small text-muted">${pelicula.sinopsis}</p>` : ''}
                                        <span class="badge bg-secondary">${pelicula.clasificacion}</span>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <button class="btn btn-outline-danger btn-sm" onclick="eliminarPelicula(${pelicula.id})">
                                            <i class="fas fa-trash me-1"></i>Eliminar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    listaElement.appendChild(div);
                });
                
            } catch (error) {
                console.error('Error al cargar películas:', error);
                listaElement.innerHTML = `
                    <div class="col-12 text-center">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>Error al cargar las películas
                        </div>
                    </div>
                `;
            } finally {
                loadingElement.style.display = 'none';
            }
        }

        // Función para eliminar película
        async function eliminarPelicula(id) {
            if (!confirm('¿Está seguro de eliminar esta película? Esta acción no se puede deshacer.')) {
                return;
            }

            try {
                const response = await fetch(`http://localhost:3000/api/peliculas/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    showAlert('Película eliminada correctamente', 'success');
                    // Recargar la lista automáticamente
                    await cargarPeliculas();
                } else {
                    const error = await response.json();
                    showAlert(error.error || 'Error al eliminar película', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Error de conexión al eliminar', 'danger');
            }
        }

        // Función para mostrar alertas
        function showAlert(message, type) {
            // Remover alertas anteriores
            const existingAlerts = document.querySelectorAll('.alert-toast');
            existingAlerts.forEach(alert => alert.remove());

            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show alert-toast`;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);
            
            // Auto-remover después de 4 segundos
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 4000);
        }
    </script>
</body>
</html>